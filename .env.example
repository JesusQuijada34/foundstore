# Configuración de la Aplicación
SECRET_KEY=tu_clave_secreta_aqui
PORT=8000

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=tu_client_id_aqui
GITHUB_OAUTH_CLIENT_SECRET=tu_client_secret_aqui
# Opcional: especifica la URL de redirección explícitamente
# Si no se proporciona, Flask-Dance la genera automáticamente
# GITHUB_OAUTH_REDIRECT_URI=https://tu-dominio.com/login/github/authorized

# MongoDB
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/foundstore?retryWrites=true&w=majority

# Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_BOT_USERNAME=infl_foundstorebot
# URL base de la web (para que el bot sepa a donde apuntar)
WEB_BASE_URL=https://foundstore.onrender.com

# (Opcional) Redis para cache distribuido entre workers
# Si no se configura, se usa cache in-process (L1)
# REDIS_URL=redis://localhost:6379/0
